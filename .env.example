# Neo4j Configuration
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=

# Application Settings
FRONTEND_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
QUOTES_FILE=data/extracted_quotes.json
BATCH_SIZE=1000
SEARCH_LIMIT=5
LOG_LEVEL=INFO

# ASR backend: mlx for Apple Silicon local development, faster for Linux/Azure.
ASR_BACKEND=faster
ASR_MODEL_NAME=Systran/faster-whisper-small
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_BEAM_SIZE=5

# Frontend build-time API URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# File paths
XML_FILE=enwikiquote-20250601-pages-articles.xml
DATA_DIR=data
DB_PATH=data/wikiquote_voice.db
